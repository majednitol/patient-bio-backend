# CA server
CA_NAMES=("ca-orderer" "ca-patient" "ca-doctor" "ca-pathologist" "ca-pharmacy" "ca-medlab" "ca-admin")
CA_PORTS=(10054 7054 8054 9054 11054 12054 13054)
CA_ORG_NAMES=("orderer" "patient" "doctor" "pathologist" "pharmacy" "medlab" "admin")
ORG_NAMES=("orderer" "patient" "doctor" "pathologist" "pharmacy" "medlab" "admin")

# Orderer 
ORDERER_IMAGE="hyperledger/fabric-orderer:2.4.9"
GRPC_PORT=7050
METRICS_PORT=9443

# Orderer name and FQDN (hostname)
ORDERERS=(
  "orderer:orderer.rono.com"
  "orderer2:orderer2.rono.com"
  "orderer3:orderer3.rono.com"
  "orderer4:orderer4.rono.com"
  "orderer5:orderer5.rono.com"
)

# Peer MSPs (renamed)
MSPS=("PatientMSP" "DoctorMSP" "PathologistMSP" "PharmacyMSP" "MedlabMSP" "AdminMSP")

# Chaincode pod 
CHAINCODE_IMAGE="majedur708/hlf-api:18.100.60"
CHAINCODE_PORT=7052
FILE_PATH="/opt/gopath/src/github.com/chaincode/basic/packaging/package_identifiers.txt"

# Updated ORG_LIST
ORG_LIST=("patient" "doctor" "pathologist" "pharmacy" "medlab" "admin")

# Lifecycler
CHANNEL_NAME="mychannel"
CHAINCODE_NAME="basic"
CHAINCODE_VERSION="1.0"
SEQUENCE="1"
ORDERER_ADDRESS="orderer:7050"
ORDERER_CA_PATH="/organizations/ordererOrganizations/rono.com/orderers/orderer.rono.com/msp/tlscacerts/tlsca.rono.com-cert.pem"

# Peer ports mapping
PEER_PORTS=(7051 9051 11051 12051 13051 14051)

ORDERER_DOMAIN="rono.com"
MAIN_DOMAIN="rono.com"
ORDERER_NAMES=("orderer" "orderer2" "orderer3" "orderer4" "orderer5")

# Updated chaincode package names
PACKAGES=(basic-patient.tgz basic-doctor.tgz basic-pathologist.tgz basic-pharmacy.tgz basic-medlab.tgz basic-admin.tgz)

# CA orderer
CA_NAME="ca-orderer"
CA_PORT="10054"
CA_HOST="ca-orderer"
CA_URL="https://admin:adminpw@$CA_HOST:$CA_PORT"
TLS_CERT_PATH="/organizations/fabric-ca/orderer/tls-cert.pem"

PORT_MAP=(7054 8054 9054 11054 12054 13054)

# Updated ORGS array
ORGS=(
  "patient Patient 7051 7054"
  "doctor Doctor 9051 8054"
  "pathologist Pathologist 11051 9054"
  "pharmacy Pharmacy 12051 11054"
  "medlab Medlab 13051 12054"
  "admin Admin 14051 13054"
)